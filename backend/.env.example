# Copy this file to `.env` (same folder) and fill in real values.
# `.env` is git-ignored — never commit real secrets.
#
# IMPORTANT: this file is parsed as a Java .properties file, NOT a shell script.
#   - No `export`, no surrounding quotes (quotes become part of the value).
#   - `KEY=value`, one per line. `#` starts a comment.
#   - Colons in values (like the API key) are fine.

# Circle sandbox API key (PREFIX:ID:SECRET). Sandbox keys start with TEST_API_KEY.
CIRCLE_API_KEY=TEST_API_KEY:your-id:your-secret

# 64-hex-char entity secret you generated + registered with Circle.
CIRCLE_ENTITY_SECRET=your-64-hex-char-entity-secret

# Wallet Set ID (fill in after first run creates one, so wallets are reused).
CIRCLE_WALLET_SET_ID=

# Shared secret the React frontend sends as X-App-Api-Key (any string for dev).
APP_API_KEY=local-dev-key

# Public HTTPS URL Circle posts wallet webhooks to (your current ngrok URL).
CIRCLE_WEBHOOK_ENDPOINT=https://your-id.ngrok-free.dev/api/webhooks/circle/wallets

# --- Production auth (only used with SPRING_PROFILES_ACTIVE=prod) ---
# Your OIDC provider's issuer URL (Auth0/Cognito/Okta/Entra/Keycloak). When set
# and running the 'prod' profile, the API requires a valid JWT bearer token.
# Leave blank/unset for local dev (falls back to the X-App-Api-Key shared key).
# OAUTH2_ISSUER_URI=https://your-tenant.us.auth0.com/
